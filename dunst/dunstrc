[global]
    monitor = 0
    follow = mouse

    # --- Tighter Geometry ---
    width = 280                # Reduced from 350
    height = (0, 80)           # Lower profile
    origin = top-right
    offset = (20, 50)

    # --- Snappier Visuals ---
    transparency = 0
    frame_width = 1            # Thinner border for a smaller box
    corner_radius = 8          # Slightly tighter corners
    font = JetBrainsMono Nerd Font 9
    padding = 10               # Tighter internal spacing
    horizontal_padding = 12
    text_icon_padding = 10
    icon_position = left
    max_icon_size = 50         # Smaller icon for the smaller height

    # --- Gray Monochromatic Palette ---
    background = "#121212"
    foreground = "#eeeeee"
    frame_color = "#555555"
    separator_color = "#333333"
    highlight = "#ffffff"
    
    # --- Faster Timing ---
    timeout = 3                # Disappears in 3 seconds
    markup = full

[urgency_low]
    background = "#121212"
    foreground = "#888888"
    frame_color = "#333333"
    timeout = 2

[urgency_normal]
    background = "#121212"
    foreground = "#eeeeee"
    frame_color = "#555555"
    timeout = 3                # Matched to global snappy speed

[urgency_critical]
    background = "#eeeeee"
    foreground = "#121212"
    frame_color = "#ffffff"
    timeout = 0                # Critical still stays until clicked

# --- THE SPOTIFY RULE ---
[spotify_notification]
    appname = "Spotify"
    background = "#1a1a1a"
    foreground = "#ffffff"
    frame_color = "#777777"
    timeout = 4                # A tiny bit longer so you can read the album name
